FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#inputSyntax slash;

#include "$FOAM_CASE/system/blockMeshDict"

actions
(
	//Cilindro
    {
        name    cylinder;
        type    cellSet;
        action  new;
        source  cylinderToCell;
        sourceInfo
        {
            p1	(0 0 0);
            p2	(0 0 $L);
            radius	$r;
        }
    }
    {
        name    solid;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        sourceInfo
        {
        	set cylinder;
        }
    }

	//Borda
    {
        name    cylinder;
        type    cellSet;
        action  invert;
    }
    {
        name    fluid;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        sourceInfo
        {
        	set cylinder;
        }
    }

);

