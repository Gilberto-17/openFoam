FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{
/*
	".*Border"
	{
		type	compressible::epsilonWallFunction;
		value	$internalField;
	}
*/	
	".*Border"
	{
		type	symmetryPlane;
	}
    fluid_to_solid
    {
        type            compressible::epsilonWallFunction;
        value           $internalField;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


