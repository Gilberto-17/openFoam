FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "$FOAM_CASE/constant/initialConditions"

dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform $Tinitial;

boundaryField
{
	cylinderBottom
	{
		type	fixedValue;
		value	uniform 327.1;	// 54.1C
	}
	cylinderTop
	{
		type	fixedValue;
		value	uniform $Tinitial;	// 295K or 22C
	}
    solid_to_fluid
    {
        type            compressible::turbulentTemperatureCoupledBaffleMixed;
        value           $internalField;
        kappa           kappa;
        Tnbr            T;
    }
}

