FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes  // OK
{
    default         steadyState;
}

gradSchemes // OK
{
    default         Gauss linear;   // cellLimited Gauss linear 0.5?
}

divSchemes  // OK
{
    default         none;
}

laplacianSchemes    // OK
{
    default         Gauss linear limited 1;
}

interpolationSchemes    // OK
{
    default         linear;
}

snGradSchemes   // OK
{
    default         limited 1;
}

