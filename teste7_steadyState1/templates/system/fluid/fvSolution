FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers // OK
{
    "(rho|rhoFinal)"
    {
        solver          PCG
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0;
    }

    p_rgh
    {
        solver           GAMG;
        tolerance        1e-7;  // 1e-6?
        relTol           0.01;

        smoother         GaussSeidel;

        maxIter          100;
    }

    "(U|h|e|k|omega|epsilon)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;   // 1e-8?
        relTol          0.1;    // 0.01?
    }

    p_rghFinal
    {
        $p_rgh;
        relTol         0;
    }

    "(U|h|e|k|omega|epsilon)Final"
    {
        $U;
        relTol          0;
    }
}

PIMPLE  // OK
{
    nCorrectors     3;  // 2
    nNonOrthogonalCorrectors 1;
//    pRefCell        0;
//    pRefValue       0;
}

relaxationFactors   // OK
{
    fields
    {
//        rho             1.0;
        p_rgh           0.5;    // 0.7
    }
    equations
    {
        "(U|h|e|k|omega|epsilon)"  0.7; // 0.7
    }
}

