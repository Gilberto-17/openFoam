FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes	// OK
{
    default             steadyState;
}

gradSchemes // OK
{
    default             cellLimited Gauss linear 0.5;   //0.5

    grad(U)             cellLimited Gauss linear 1;
    grad(k)             cellLimited Gauss linear 1; // 0.5?
    grad(omega)         cellLimited Gauss linear 1; // 0.5?
    grad(epsilon)       cellLimited Gauss linear 1; // 0.5?
}

divSchemes  // OK
{
    default             none;

    div(phi,U)          bounded Gauss linearUpwind grad(U);

//                      bounded Gauss limitedLinear 1;
    div(phi,k)          bounded Gauss linearUpwind grad(k);
    div(phi,omega)      bounded Gauss linearUpwind grad(omega);
    div(phi,epsilon)    bounded Gauss linearUpwind grad(epsilon);

    div(phi,e)          bounded Gauss limitedLinear 1;
    div(phi,h)          bounded Gauss limitedLinear 1;
    div(phi,K)          bounded Gauss limitedLinear 1;
    div(phi,Ekp)        bounded Gauss limitedLinear 1;

    div(phid,p)                         Gauss upwind;   // Verify
    div((phi|interpolate(rho)),p)       Gauss upwind;   // Verify

    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;   // Verified
}

laplacianSchemes	// OK
{
    default             Gauss linear limited 1;
}

interpolationSchemes    // OK
{
    default             linear;
}

snGradSchemes	// OK
{
    default             limited 1;
}

fluxRequired
{
    default         no;
    p                 ;
}

wallDist
{
    method meshWave;
}

