FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

L		0.6054;
r		0.0048;
ang		45.0;
//ieratio	0.25;

x_cemax	#calc "$r*cos(degToRad($ang))";
x_cemin	#calc "-1.0*$x_cemax";
y_cemax	#calc "$r*sin(degToRad($ang))";
y_cemin	#calc "-1.0*$y_cemax";

/*
x_cimax	#calc "$ieratio*$x_cemax";
x_cimin	#calc "-1*$x_cimax";
y_cimax	#calc "$ieratio*$y_cemax";
y_cimin	#calc "-1*$y_cimax";
*/

border		0.3;

x_bmin		#calc "-1.0*$border";
x_bmax		$border;
y_bmin		#calc "-1.0*$border";
y_bmax		$border;

d1m		20;	// direction 1 mesh
// d2m		10;	// direction 2 mesh
d3m		60;	// direction 3 mesh
d4m		50;	// direction 4 mesh

sg3		8;
sg4		20;

convertToMeters 1;

vertices
(
	// Cylinder
//	name A1 ($x_cimin	$y_cimin	0)	// 0 A
//	name B1 ($x_cimax	$y_cimin	0)	// 1 B
//	name C1 ($x_cimax	$y_cimax	0)	// 2 C
//	name D1 ($x_cimin	$y_cimax	0)	// 3 D
	name E1 ($x_cemin	$y_cemin	0)	// 4 E
	name F1 ($x_cemax	$y_cemin	0)	// 5 F
	name G1 ($x_cemax	$y_cemax	0)	// 6 G
	name H1 ($x_cemin	$y_cemax	0)	// 7 H
	
//	name A2 ($x_cimin	$y_cimin	$L)	// 8 A
//	name B2 ($x_cimax	$y_cimin	$L)	// 9 B
//	name C2 ($x_cimax	$y_cimax	$L)	// 10 C
//	name D2 ($x_cimin	$y_cimax	$L)	// 11 D
	name E2 ($x_cemin	$y_cemin	$L)	// 12 E
	name F2 ($x_cemax	$y_cemin	$L)	// 13 F
	name G2 ($x_cemax	$y_cemax	$L)	// 14 G
	name H2 ($x_cemin	$y_cemax	$L)	// 15 H
	
	//Border
	name I1 ($x_bmin	$y_bmin		0)	// 16 I
	name J1 ($x_bmax	$y_bmin		0)	// 17 J
	name K1 ($x_bmax	$y_bmax		0)	// 18 K
	name L1 ($x_bmin	$y_bmax		0)	// 19 L
	
	name I2 ($x_bmin	$y_bmin		$L)	// 20 I
	name J2 ($x_bmax	$y_bmin		$L)	// 21 J
	name K2 ($x_bmax	$y_bmax		$L)	// 22 K
	name L2 ($x_bmin	$y_bmax		$L)	// 23 L
	
); 

blocks
(
	// Cyilnder
//	hex (3 2 6 7 11 10 14 15) ($d1m $d2m $d3m) simpleGrading (1 1 $sg3)					// block 0 DCGH
//	hex (2 1 5 6 10 9 13 14) ($d1m $d2m $d3m) simpleGrading (1 1 $sg3)					// block 1 CBFG
//	hex (1 0 4 5 9 8 12 13) ($d1m $d2m $d3m) simpleGrading (1 1 $sg3)					// block 2 BAEF
//	hex (0 3 7 4 8 11 15 12) ($d1m $d2m $d3m) simpleGrading (1 1 $sg3)					// block 3 ADHE
//	hex (3 0 1 2 11 8 9 10) ($d1m $d1m $d3m) simpleGrading (1 1 $sg3)					// block 4 DABC
		hex (E1 F1 G1 H1 E2 F2 G2 H2) ($d1m $d1m $d3m) simpleGrading (1 1 $sg3)					// block 4 EFGH
	
	// Border
	hex (H1 G1 K1 L1 H2 G2 K2 L2) ($d1m $d4m $d3m) simpleGrading (1 $sg4 $sg3)	// block 5 HGKL
	hex (G1 F1 J1 K1 G2 F2 J2 K2) ($d1m $d4m $d3m) simpleGrading (1 $sg4 $sg3)	// block 6 GFJK
	hex (F1 E1 I1 J1 F2 E2 I2 J2) ($d1m $d4m $d3m) simpleGrading (1 $sg4 $sg3)	// block 7 FEIJ
	hex (E1 H1 L1 I1 E2 H2 L2 I2) ($d1m $d4m $d3m) simpleGrading (1 $sg4 $sg3)	// block 5 EHLI
);

edges
(
	arc G1 H1 90 	(0 0 1)	// block 0 side bottom	GH
	arc G2 H2 90 	(0 0 1)	// block 0 side top		GH
	arc F1 G1 90 	(0 0 1)	// block 1 side bottom	FG
	arc F2 G2 90 	(0 0 1)	// block 1 side top		FG
	arc E1 F1 90 	(0 0 1)	// block 2 side bottom	EF
	arc E2 F2 90 	(0 0 1)	// block 2 side top		EF
	arc H1 E1 90 	(0 0 1)	// block 3 side bottom	HE
	arc H2 E2 90 	(0 0 1)	// block 3 side top		HE

/*	
	arc 2 3 90 	(0 0 1)	// block 4 side 0 bottom	CD
	arc 10 11 90 	(0 0 1)	// block 4 side 0 top		CD
	arc 1 2 90 	(0 0 1)	// block 4 side 1 bottom	BC
	arc 9 10 90 	(0 0 1)	// block 4 side 1 top		BC
	arc 0 1 90 	(0 0 1)	// block 4 side 2 bottom	AB
	arc 8 9 90 	(0 0 1)	// block 4 side 2 top		AB
	arc 3 0 90 	(0 0 1)	// block 4 side 3 bottom	DA
	arc 11 8 90 	(0 0 1)	// block 4 side 3 top		DA
*/
);

boundary
(
	//Cylinder
	cylinderBottom
	{
		type	wall;
		faces
		(
//			(3 2 6 7)	// block 0 bottom
//			(2 1 5 6)	// block 1 bottom
//			(1 0 4 5)	// block 2 bottom
//			(0 3 7 4)	// block 3 bottom
//			(3 0 1 2)	// block 4 bottom
			(E1 F1 G1 H1)	// block 4.1 bottom
		);
	}
	cylinderTop
	{
		type	wall;
		faces
		(
//			(11 10 14 15)	// block 0 top
//			(10 9 13 14)	// block 1 top
//			(9 8 12 13)	// block 2 top
//			(8 11 15 12)	// block 3 top
//			(11 8 9 10)	// block 4 top
			(E2 F2 G2 H2)	// block 4.1 top
		);
	}
/*
	cylinderWall
	{
		type	wall;
		faces
		(
			(6 7 15 14)	// block 0 side
			(5 6 14 13)	// block 1 side
			(4 5 13 12)	// block 2 side
			(7 4 12 15)	// block 3 side
		);
	}
*/

	//Border
	westBorder
	{
		type	symmetryPlane;
		faces
		(
			(I2 L2 L1 I1)
		);
	}
	eastBorder
	{
		type	symmetryPlane;
		faces
		(
			(K2 J2 J1 K1)
		);
	}
	southBorder
	{
		type	symmetryPlane;
		faces
		(
			(I1 J1 J2 I2)
		);
	}
	northBorder
	{
		type	symmetryPlane;
		faces
		(
			(K1 L1 L2 K2)
		);
	}
	bottomBorder
	{
		type	symmetryPlane;
		faces
		(
			(H1 G1 K1 L1)
			(G1 F1 J1 K1)
			(F1 E1 I1 J1)
			(E1 H1 L1 I1)
		);
	}
	topBorder
	{
		type	symmetryPlane;
		faces
		(
			(H2 G2 K2 L2)
			(G2 F2 J2 K2)
			(F2 E2 I2 J2)
			(E2 H2 L2 I2)
		);
	}
	
);

mergePatchPairs
(
);

